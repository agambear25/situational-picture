# Copy to .env (gitignored) and fill in. NEVER commit the real .env.

# --- NASA FIRMS (thermal feed) ---
# Free, instant, no login. Get it at: https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Enter your email; the MAP_KEY is issued on the page immediately.
FIRMS_MAP_KEY=
# Optional: how many days back to pull each FIRMS run (1..10).
FIRMS_DAY_RANGE=1
# Optional offline override: a local FIRMS CSV instead of the live API.
# FIRMS_FILE=/path/to/firms_export.csv

# --- UCDP GED (text feed) ---
# Open, CC-BY 4.0, NO key required. Optional overrides only:
# UCDP_GED_VERSION=24.1
# UCDP_COUNTRY=Ukraine
# Optional offline override: a local UCDP CSV/JSON instead of the API.
# UCDP_GED_FILE=/path/to/ged_ukraine.csv

# --- Database ---
# Engine (owner) DSN used by ingest + migrations.
DB_DSN=postgresql://localhost:5432/osint_cop
# Read-only API role DSN used by the FastAPI service.
DB_DSN_API=postgresql://cop_api:changeme@localhost:5432/osint_cop

# --- Google Earth Engine (Phase 3b+: Sentinel-1 SAR + Sentinel-2 optical acquisition) ---
#
# GEE does NOT use an API key. It uses OAuth2. One-time setup:
#   1. pip install earthengine-api     (already in [full] deps)
#   2. earthengine authenticate        (opens browser → sign in with the Google account
#                                       that has GEE access → auto-writes credentials to
#                                       ~/.config/earthengine/credentials)
#   3. If you hit 'invalid_scope':     edit ~/.config/earthengine/credentials and change
#                                       "scopes" to just:
#                                       ["https://www.googleapis.com/auth/earthengine"]
#                                       (drop the devstorage scope — same fix as Yamuna)
#
# Your existing Yamuna project credentials file should work as-is.
#
# GCP project (leave empty for noncommercial research — no billing account needed):
GEE_PROJECT=
#
# Override the credentials file path only if it's NOT at the default location:
# GEE_CREDENTIALS_PATH=~/.config/earthengine/credentials
#
# Local tile cache directory (raw downloaded imagery, can be GB — gitignored):
GEE_TILE_CACHE_DIR=.tile_cache
#
# Download scale in metres/pixel (100–1000; lower = larger files; 500m good for AOI-level):
GEE_SCALE_M=500

# --- PAID, OFF for the entire MVP. Leave unset. ---
# ANTHROPIC_API_KEY=
